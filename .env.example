# Supabase — public (shipped to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_BUCKET=ghg

# Supabase — server only (Route Handlers / Server Actions)
SUPABASE_SERVICE_ROLE_KEY=

# Cloud Run backend — server only
BACKEND_API_URL=
BACKEND_API_TOKEN=

# Google Cloud auth for Cloud Run (the backend runs with --no-allow-unauthenticated).
#
# Local dev: point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON
# key file (Application Default Credentials).
#   GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json
#
# Vercel (no persistent filesystem): paste the full JSON content into
# GOOGLE_CREDENTIALS_JSON instead. Our ghg-auth helper prefers this when set.
#   GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}
#
# On Cloud Run / GCE, the platform identity is picked up automatically — leave both unset.
#
# Escape hatch while backend still allows unauthenticated invocations:
#   GHG_SKIP_GOOGLE_AUTH=1
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CREDENTIALS_JSON=
